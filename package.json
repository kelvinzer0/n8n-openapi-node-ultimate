{
  "name": "@kelvinzer0/n8n-openapi-node-ultimate",
  "version": "1.0.0",
  "description": "Turn OpenAPI specs into n8n node properties — with URL import, CLI, and enhanced schema support",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "n8n-openapi-gen": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kelvinzer0/n8n-openapi-node-ultimate.git"
  },
  "keywords": [
    "n8n",
    "openapi",
    "swagger",
    "codegen",
    "automation",
    "workflow"
  ],
  "author": "kelvinzer0",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kelvinzer0/n8n-openapi-node-ultimate/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/kelvinzer0/n8n-openapi-node-ultimate#readme",
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.7",
    "jest": "^29.7.0",
    "n8n-core": "*",
    "n8n-workflow": "*",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "openapi-types": "^12.1.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2"
  }
}
